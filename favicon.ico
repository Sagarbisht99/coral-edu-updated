<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Favicon Generator</title>
</head>
<body>
    <canvas id="canvas" width="64" height="64"></canvas>
    <script>
        // Load the logo image
        const img = new Image();
        img.crossOrigin = "anonymous";
        img.src = 'assets/logo.png';
        
        img.onload = function() {
            const canvas = document.getElementById('canvas');
            const ctx = canvas.getContext('2d');
            
            // Clear canvas
            ctx.clearRect(0, 0, 64, 64);
            
            // Draw the image centered and scaled
            const size = Math.min(img.width, img.height);
            const scale = 64 / size;
            const x = (64 - size * scale) / 2;
            const y = (64 - size * scale) / 2;
            
            ctx.drawImage(img, x, y, size * scale, size * scale);
            
            // Convert to favicon
            const favicon = document.createElement('link');
            favicon.rel = 'icon';
            favicon.type = 'image/x-icon';
            favicon.href = canvas.toDataURL('image/x-icon');
            
            document.head.appendChild(favicon);
            
            // Also create Apple touch icon
            const appleTouchIcon = document.createElement('link');
            appleTouchIcon.rel = 'apple-touch-icon';
            appleTouchIcon.href = canvas.toDataURL('image/png');
            document.head.appendChild(appleTouchIcon);
        };
        
        img.onerror = function() {
            console.error('Failed to load logo image');
            // Create a simple fallback favicon
            const canvas = document.getElementById('canvas');
            const ctx = canvas.getContext('2d');
            
            // Create a simple "C" favicon as fallback
            ctx.fillStyle = '#ff7a00';
            ctx.fillRect(0, 0, 64, 64);
            ctx.fillStyle = '#fff';
            ctx.font = 'bold 48px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('C', 32, 38);
            
            // Convert to favicon
            const favicon = document.createElement('link');
            favicon.rel = 'icon';
            favicon.type = 'image/x-icon';
            favicon.href = canvas.toDataURL('image/x-icon');
            
            document.head.appendChild(favicon);
        };
    </script>
</body>
</html>
